output "Shenzhen KTC Technology Group H24T7 0x00000001" {
  mode 2560x1440@180.000
  position 0,0
  alias $LEFT
}

output "Philips Consumer Electronics Company PHL 243V7 UHB1917003005" {
  position 2560,0
  alias $RIGHT
}

output HDMI-A-1 {
  position 9001,9001
  alias $HEADLESS
}

profile default {
  output $LEFT enable
  output $RIGHT disable
  output $HEADLESS enable
  exec swaymsg workspace 20, move workspace to HDMI-A-1
}

profile dual {
  output $LEFT enable
  output $RIGHT enable
  output $HEADLESS enable
}
