{
    "apps": [
        {
            "allow-client-commands": false,
            "image-path": "desktop.png",
            "name": "Desktop",
            "uuid": "96B20779-F181-AC26-7B1F-60CB82C05A38"
        },
        {
            "auto-detach": true,
            "cmd": "",
            "detached": [
                "sh -c \"gamescope -W $SUNSHINE_CLIENT_WIDTH -H $SUNSHINE_CLIENT_HEIGHT -w $SUNSHINE_CLIENT_WIDTH -h $SUNSHINE_CLIENT_HEIGHT -f --force-grab-cursor -S stretch -- /usr/bin/heroic\""
            ],
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "lutris.png",
            "name": "Heroic Launcher",
            "prep-cmd": [
                {
                    "do": "sh -c \"swaymsg output HDMI-A-1 mode ${SUNSHINE_CLIENT_WIDTH}x${SUNSHINE_CLIENT_HEIGHT}@60.000Hz\"",
                    "undo": "swaymsg output HDMI-A-1 mode 1920x1080@60.000Hz"
                },
                {
                    "do": "swaymsg workspace 20",
                    "undo": ""
                }
            ],
            "uuid": "E1B3F279-4A12-4C3D-9E88-1234567890AB",
            "wait-all": true
        },
        {
            "auto-detach": true,
            "cmd": "",
            "detached": [
                "sh -c \"gamescope -W $SUNSHINE_CLIENT_WIDTH -H $SUNSHINE_CLIENT_HEIGHT -w $SUNSHINE_CLIENT_WIDTH -h $SUNSHINE_CLIENT_HEIGHT -f -e --force-grab-cursor -S stretch -- steam steam://open/bigpicture\""
            ],
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "steam.png",
            "name": "Steam Big Picture",
            "prep-cmd": [
                {
                    "do": "",
                    "undo": "steam -shutdown"
                },
                {
                    "do": "sh -c \"swaymsg output HDMI-A-1 mode ${SUNSHINE_CLIENT_WIDTH}x${SUNSHINE_CLIENT_HEIGHT}@60.000Hz\"",
                    "undo": "swaymsg output HDMI-A-1 mode 1920x1080@60.000Hz"
                },
                {
                    "do": "swaymsg workspace 20",
                    "undo": ""
                }
            ],
            "uuid": "9A85098B-009B-3702-0D9C-7729FE85FCF3",
            "wait-all": true
        }
    ],
    "env": {
        "MANGOHUD": "1",
        "MANGOHUD_CONFIG": "fps_limit=60,no_display",
        "PATH": "$(PATH):$(HOME)/.local/bin",
        "PROTON_USE_WAYLAND": "0"
    },
    "version": 2
}
